---
import content from '../data/content.json';

const { links, socialLinks, webApps, admin } = content.nav;
---

<nav class="sticky top-0 z-50 bg-navy text-white shadow-lg">
  <div class="mx-auto max-w-7xl px-4">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo + section links -->
      <div class="flex items-center gap-6">
        <a href="#" class="shrink-0">
          <img src="/images/logo.webp" alt="Site Logo" class="h-10 w-10" loading="lazy" />
        </a>

        <!-- Desktop section links -->
        <div class="hidden items-center gap-1 md:flex">
          {links.map((link) => (
            <a
              href={link.href}
              class="rounded px-3 py-2 text-sm font-medium transition-colors hover:bg-white/10"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Right side: social links + dropdowns (desktop) -->
      <div class="hidden items-center gap-2 md:flex">
        <!-- Social links -->
        {socialLinks.map((link) => (
          <a
            href={link.href}
            class="rounded px-3 py-2 text-sm font-medium transition-colors hover:bg-white/10"
            target="_blank"
            rel="noopener noreferrer"
          >
            {link.label}
          </a>
        ))}

        <span class="mx-1 h-5 w-px bg-white/20"></span>

        <!-- Web Apps dropdown -->
        <div class="relative">
          <button
            data-dropdown="web-apps"
            class="rounded px-3 py-2 text-sm font-medium transition-colors hover:bg-white/10"
          >
            Web Apps
            <svg class="ml-1 inline h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            id="dropdown-web-apps"
            class="absolute right-0 z-50 mt-2 hidden w-72 rounded-md bg-white py-2 shadow-lg ring-1 ring-navy/10"
          >
            {webApps.map((app) => (
              <a href={app.href} class="block px-4 py-2 text-sm text-navy hover:bg-navy hover:text-white">
                {app.label}
              </a>
            ))}
          </div>
        </div>

        <!-- Admin dropdown -->
        <div class="relative">
          <button
            data-dropdown="admin"
            class="rounded px-3 py-2 text-sm font-medium transition-colors hover:bg-white/10"
          >
            Admin
            <svg class="ml-1 inline h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            id="dropdown-admin"
            class="absolute right-0 z-50 mt-2 hidden w-72 rounded-md bg-white py-2 shadow-lg ring-1 ring-navy/10"
          >
            <p class="bg-navy px-4 py-1 text-center text-sm font-semibold text-white">Management Consoles</p>
            {admin.management.map((item) => (
              <a href={item.href} class="block px-4 py-2 text-sm text-navy hover:bg-navy hover:text-white">
                {item.label}
              </a>
            ))}
            <p class="mt-2 bg-navy px-4 py-1 text-center text-sm font-semibold text-white">Personal Apps</p>
            {admin.personal.map((item) => (
              <a href={item.href} class="block px-4 py-2 text-sm text-navy hover:bg-navy hover:text-white">
                {item.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="rounded p-2 text-white hover:bg-white/10 md:hidden"
        aria-label="Toggle navigation"
      >
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-white/10 md:hidden">
    <div class="space-y-1 px-4 py-3">
      {links.map((link) => (
        <a href={link.href} class="mobile-nav-link block rounded px-3 py-2 text-sm hover:bg-white/10">
          {link.label}
        </a>
      ))}
      <div class="my-2 border-t border-white/10"></div>
      {socialLinks.map((link) => (
        <a href={link.href} class="block rounded px-3 py-2 text-sm hover:bg-white/10" target="_blank" rel="noopener noreferrer">
          {link.label}
        </a>
      ))}
      <p class="mt-3 px-3 text-xs font-semibold uppercase tracking-wider text-white/50">Web Apps</p>
      {webApps.map((app) => (
        <a href={app.href} class="block rounded px-3 py-2 text-sm hover:bg-white/10">
          {app.label}
        </a>
      ))}
      <p class="mt-3 px-3 text-xs font-semibold uppercase tracking-wider text-white/50">Admin</p>
      {[...admin.management, ...admin.personal].map((item) => (
        <a href={item.href} class="block rounded px-3 py-2 text-sm hover:bg-white/10">
          {item.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  mobileBtn?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));

  // Close mobile menu when a section link is tapped
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => mobileMenu?.classList.add('hidden'));
  });

  // Click-to-open dropdowns
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const trigger = target.closest('[data-dropdown]') as HTMLElement | null;
    const allPanels = document.querySelectorAll('[id^="dropdown-"]');

    if (trigger) {
      const panelId = 'dropdown-' + trigger.dataset.dropdown;
      const panel = document.getElementById(panelId);
      const wasOpen = panel && !panel.classList.contains('hidden');

      // Close all panels
      allPanels.forEach((p) => p.classList.add('hidden'));

      // Toggle the clicked one
      if (!wasOpen && panel) panel.classList.remove('hidden');
      return;
    }

    // Click outside — close all
    if (!target.closest('[id^="dropdown-"]')) {
      allPanels.forEach((p) => p.classList.add('hidden'));
    }
  });

  // Escape key closes dropdowns
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll('[id^="dropdown-"]').forEach((p) => p.classList.add('hidden'));
    }
  });
</script>
