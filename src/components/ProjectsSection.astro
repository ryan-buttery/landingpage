---
import SectionHeading from './SectionHeading.astro';

interface Props {
  title: string;
  intro: string;
  items: string[];
}

const { title, intro, items } = Astro.props;
---

<section id="projects" class="bg-gray-50 py-16 px-4">
  <div class="mx-auto max-w-4xl">
    <SectionHeading title={title} />
    <p class="mt-8 text-center leading-relaxed text-navy/80">{intro}</p>
    <div class="mt-10 space-y-4">
      {items.map((item) => (
        <div class="rounded-lg border border-navy/5 bg-white p-6 shadow-sm">
          <p class="text-sm leading-relaxed text-navy/80" set:html={item} />
        </div>
      ))}
    </div>
  </div>
</section>
