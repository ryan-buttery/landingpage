---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="text-center">
  <h2 class="text-3xl font-bold text-navy">{title}</h2>
  {subtitle && <p class="mt-2 text-lg text-navy/70">{subtitle}</p>}
  <div class="mx-auto mt-4 h-1 w-16 rounded bg-gradient-to-r from-sky to-teal"></div>
</div>
