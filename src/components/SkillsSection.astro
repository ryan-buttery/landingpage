---
import SectionHeading from './SectionHeading.astro';

interface Props {
  title: string;
  intro: string;
  certificate: {
    verifyUrl: string;
    certificateNumber: string;
    candidateNumber: string;
    syllabusUrl: string;
    bcsUrl: string;
  };
  skills: string[];
}

const { title, intro, certificate, skills } = Astro.props;
---

<section id="skills" class="py-16 px-4">
  <div class="mx-auto max-w-4xl">
    <SectionHeading title={title} />
    <div class="mt-8 text-center">
      <p class="leading-relaxed text-navy/80" set:html={intro} />
      <p class="mt-3 text-sm text-navy/60">
        Verify my certificate at
        <a href={certificate.verifyUrl} class="text-sky underline hover:text-sky/80">BCS eCertCheck</a>
        — Certificate: {certificate.certificateNumber}, Candidate: {certificate.candidateNumber}.
      </p>
    </div>
    <div class="mt-10 grid gap-4 md:grid-cols-2">
      {skills.map((skill) => (
        <div class="rounded-lg border border-navy/10 p-5 text-sm leading-relaxed text-navy/80">
          <p set:html={skill} />
        </div>
      ))}
    </div>
  </div>
</section>
